---
import { getCollection } from "astro:content";
import HeroEarthField from "@components/HeroEarthField";
import VisitorWorldMap from "@components/VisitorWorldMap";
import SiteLayout from "@layouts/SiteLayout.astro";
import { fallbackVisitorSummary } from "@data/visitorStats";
import {
  experience,
  honors,
  profile,
  publications,
  referenceSites,
  researchAreas
} from "@data/site";

const heroStats = [
  { label: "Core field", value: "Spatial Intelligence" },
  { label: "Decision layer", value: "Causal response learning" },
  { label: "Applied systems", value: "Pricing, uplift, allocation" }
];
const homepageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: `${profile.name} Academic Homepage`,
  description: profile.summary,
  url: "https://whitneylcj.github.io/",
  mainEntity: {
    "@type": "Person",
    "@id": "https://whitneylcj.github.io/#person",
    name: profile.name
  }
};

const scholarLink = profile.contacts.find((contact) => contact.label === "Google Scholar");
const currentYear = new Date().getFullYear();
const newsEntries = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latestNews = newsEntries.slice(0, 3);
const blogEntries = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestBlog = blogEntries.filter((entry) => entry.data.featured).slice(0, 3);
const visitorApiBase = import.meta.env.PUBLIC_VISITOR_API_BASE;

function newsSlug(id: string) {
  return id.replace(/\.mdx?$/, "");
}

function blogSlug(id: string) {
  return id.replace(/\.mdx?$/, "");
}

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en", { month: "short", day: "numeric", year: "numeric" }).format(date);
}
---

<SiteLayout description={profile.summary} canonicalPath="/" jsonLd={homepageJsonLd}>
  <header class="site-header">
    <div class="container nav-wrap">
      <a class="brand" href="#top" aria-label="Changjian Liu homepage">
        <span class="brand-mark">{profile.initials}</span>
        <span class="brand-text">
          <strong>{profile.name}</strong>
          <small>Spatial x Causal x Decision</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#about">About</a>
        <a href="#research">Research</a>
        <a href="#publications">Publications</a>
        <a href="/news/">News</a>
        <a href="/blog/">Blog</a>
        <a href="#experience">Experience</a>
        <a href="#visitors">Visitors</a>
      </nav>
      <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle color theme" aria-pressed="false">
        Dark
      </button>
    </div>
  </header>

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <HeroEarthField client:load />
      <div class="container hero-content">
        <p class="section-label">Academic Homepage · Spatial Intelligence</p>
        <h1 id="hero-title">{profile.name}</h1>
        <p class="hero-subtitle">Spatial Intelligence / Causal Inference / Decision Systems</p>
        <p class="hero-summary">{profile.summary}</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button button-primary" href="#publications">View Publications</a>
          <a class="button" href="/blog/">Read Research Notes</a>
        </div>
        <div class="hero-links" aria-label="Profile links">
          {
            profile.contacts.map((contact) => (
              <a
                href={contact.href}
                target={contact.external ? "_blank" : undefined}
                rel={contact.external ? "noreferrer" : undefined}
              >
                {contact.label}
              </a>
            ))
          }
        </div>
      </div>
      <div class="container hero-signals" aria-label="Research signals">
        {
          heroStats.map((stat) => (
            <div class="signal">
              <span>{stat.label}</span>
              <strong>{stat.value}</strong>
            </div>
          ))
        }
      </div>
    </section>

    <section class="container section" id="news" aria-labelledby="news-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="section-label">News</p>
          <h2 id="news-title">Latest updates</h2>
        </div>
        <a class="text-link" href="/news/">All news</a>
      </div>
      <div class="latest-news-grid">
        {
          latestNews.map((entry) => (
            <article class="news-card">
              <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
              <h3>
                <a href={entry.data.externalUrl ?? `/news/${newsSlug(entry.id)}/`}>
                  {entry.data.title}
                </a>
              </h3>
              <p>{entry.data.summary}</p>
              <div class="tag-row">
                {entry.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section blog-home-section" id="blog" aria-labelledby="blog-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="section-label">Blog</p>
          <h2 id="blog-title">Research notes</h2>
        </div>
        <a class="text-link" href="/blog/">All posts</a>
      </div>
      <div class="blog-home-grid">
        {
          latestBlog.map((entry) => (
            <article class="blog-home-card">
              <p class="card-kicker">{entry.data.category}</p>
              <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
              <h3>
                <a href={`/blog/${blogSlug(entry.id)}/`}>{entry.data.title}</a>
              </h3>
              <p>{entry.data.summary}</p>
              <div class="tag-row">
                {entry.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section about-section" id="about" aria-labelledby="about-title">
      <div class="section-heading">
        <p class="section-label">About</p>
        <h2 id="about-title">Researcher profile</h2>
      </div>
      <div class="about-grid">
        <div class="about-copy">
          <p>
            I am currently pursuing my master's degree in <strong>Spatio-Temporal Big Data</strong> at
            <strong> Peking University</strong>, after completing my bachelor's degree in
            <strong> Computer Science and Technology</strong> at
            <strong> China University of Geosciences, Beijing</strong>.
          </p>
          <p>
            My academic background sits at the intersection of spatial intelligence and modern machine learning.
            On the application side, I work on industrial decision systems, including pricing, advertising
            optimization, and causal decision-making.
          </p>
        </div>
        <aside class="profile-panel" aria-label="Profile summary">
          <div class="avatar-shell">
            <img
              src="/avatar.jpg"
              alt="Changjian Liu avatar"
              loading="lazy"
              onerror="this.hidden=true"
            />
            <span class="avatar-fallback">{profile.initials}</span>
          </div>
          <div>
            <h3>{profile.title}</h3>
            <p>{profile.affiliation} · {profile.location}</p>
            <div class="focus-list">
              {profile.focus.map((item) => <span>{item}</span>)}
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="container section" id="research" aria-labelledby="research-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="section-label">Research</p>
          <h2 id="research-title">Research directions</h2>
        </div>
        <p class="section-note">Methods that connect spatial structure, response estimation, and real decisions.</p>
      </div>
      <div class="research-grid">
        {
          researchAreas.map((area) => (
            <article class="info-card">
              <p class="card-kicker">{area.keywords[0]}</p>
              <h3>{area.title}</h3>
              <p>{area.summary}</p>
              <div class="tag-row">
                {area.keywords.map((keyword) => <span>{keyword}</span>)}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section" id="publications" aria-labelledby="publications-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="section-label">Publications</p>
          <h2 id="publications-title">
            Publications <span>(representative papers are <mark>highlighted</mark>)</span>
          </h2>
          <p class="publication-updated">Last update: Jun 2026</p>
        </div>
        {
          scholarLink && (
            <a class="text-link" href={scholarLink.href} target="_blank" rel="noreferrer">
              Full list on Google Scholar
            </a>
          )
        }
      </div>
      <div class="publication-list">
        {
          publications.map((publication) => (
            <article class={`publication-card${publication.featured ? " publication-card-featured" : ""}`}>
              <div class="publication-figure">
                <img src={publication.figure} alt={publication.figureAlt} loading="lazy" />
              </div>
              <div class="publication-body">
                <h3>{publication.title}</h3>
                <p class="publication-authors">{publication.authors}</p>
                <p class="publication-meta">{publication.venue} · {publication.year} · {publication.role}</p>
                <p class="publication-summary">{publication.summary}</p>
                <div class="tag-row">
                  {publication.keywords.map((keyword) => <span>{keyword}</span>)}
                </div>
                {
                  publication.links?.some((link) => link.href) && (
                    <div class="publication-links" aria-label={`${publication.title} links`}>
                      {publication.links
                        .filter((link) => link.href)
                        .map((link) => (
                          <a
                            href={link.href}
                            target={link.external ? "_blank" : undefined}
                            rel={link.external ? "noreferrer" : undefined}
                          >
                            {link.label}
                          </a>
                        ))}
                    </div>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section split-section" id="experience" aria-labelledby="experience-title">
      <div>
        <div class="section-heading">
          <p class="section-label">Experience</p>
          <h2 id="experience-title">Decision systems in practice</h2>
        </div>
        <div class="timeline">
          {
            experience.map((item) => (
              <article class="timeline-item">
                <p class="timeline-date">{item.date}</p>
                <h3>{item.organization}</h3>
                <p>{item.summary}</p>
                <ul>
                  {item.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
      <aside class="honors-panel" aria-label="Honors">
        <p class="section-label">Honors</p>
        <h2>Recognition</h2>
        <ul class="honors-list">
          {honors.map((honor) => <li>{honor.title}</li>)}
        </ul>
      </aside>
    </section>

    <section class="container section" id="visitors" aria-labelledby="visitors-title">
      <VisitorWorldMap client:load fallback={fallbackVisitorSummary} apiBase={visitorApiBase} />
    </section>

    <section class="container section" id="references" aria-labelledby="references-title">
      <div class="section-heading section-heading-row">
        <div>
          <p class="section-label">References</p>
          <h2 id="references-title">Academic sites worth learning from</h2>
        </div>
        <p class="section-note">A small reference board for future homepage design iterations.</p>
      </div>
      <div class="reference-grid">
        {
          referenceSites.map((site) => (
            <a class="reference-card" href={site.href} target="_blank" rel="noreferrer">
              <strong>{site.name}</strong>
              <span>{site.takeaway}</span>
            </a>
          ))
        }
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="container footer-wrap">
      <p>© {currentYear} {profile.name}. Built with Astro for GitHub Pages.</p>
      <div class="footer-links">
        {
          profile.contacts.map((contact) => (
            <a
              href={contact.href}
              target={contact.external ? "_blank" : undefined}
              rel={contact.external ? "noreferrer" : undefined}
            >
              {contact.label}
            </a>
          ))
        }
      </div>
    </div>
  </footer>
</SiteLayout>
