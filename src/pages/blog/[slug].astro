---
import { getCollection, render, type CollectionEntry } from "astro:content";
import SiteLayout from "@layouts/SiteLayout.astro";
import { profile } from "@data/site";

type Props = {
  entry: CollectionEntry<"blog">;
};

export async function getStaticPaths() {
  const entries = (await getCollection("blog")).filter((entry) => !entry.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const slug = entry.id.replace(/\.mdx?$/, "");
const canonicalPath = `/blog/${slug}/`;
const canonicalUrl = new URL(canonicalPath, "https://whitneylcj.github.io").toString();
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  author: {
    "@type": "Person",
    "@id": "https://whitneylcj.github.io/#person",
    name: profile.name
  },
  publisher: {
    "@type": "Person",
    "@id": "https://whitneylcj.github.io/#person",
    name: profile.name
  },
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  keywords: entry.data.tags,
  articleSection: entry.data.category
};

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en", { month: "long", day: "numeric", year: "numeric" }).format(date);
}
---

<SiteLayout
  title={`${entry.data.title} | ${profile.name}`}
  description={entry.data.summary}
  canonicalPath={canonicalPath}
  image={entry.data.heroImage}
  type="article"
  publishedDate={entry.data.date}
  updatedDate={entry.data.date}
  jsonLd={articleJsonLd}
>
  <header class="site-header">
    <div class="container nav-wrap">
      <a class="brand" href="/" aria-label="Back to homepage">
        <span class="brand-mark">{profile.initials}</span>
        <span class="brand-text">
          <strong>{profile.name}</strong>
          <small>{entry.data.category}</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Blog navigation">
        <a href="/#about">About</a>
        <a href="/#publications">Publications</a>
        <a href="/news/">News</a>
        <a href="/blog/">Blog</a>
      </nav>
      <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle color theme" aria-pressed="true">
        Dark
      </button>
    </div>
  </header>

  <main class="subpage-main">
    <article class="container blog-detail">
      <div class="blog-detail-grid">
        <div class="blog-article-main">
          <a class="text-link" href="/blog/">Back to all posts</a>
          <p class="section-label">{entry.data.category}</p>
          <h1>{entry.data.title}</h1>
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          <p class="blog-summary">{entry.data.summary}</p>
          <div class="tag-row">
            {entry.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
          {entry.data.heroImage && <img class="blog-hero-image" src={entry.data.heroImage} alt="" loading="lazy" />}
          <div class="blog-body">
            <Content />
          </div>
        </div>
        {
          toc.length > 0 && (
            <aside class="blog-toc" aria-label="Table of contents">
              <p>On this page</p>
              <ol>
                {toc.map((heading) => (
                  <li class={`toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            </aside>
          )
        }
      </div>
    </article>
  </main>
</SiteLayout>
