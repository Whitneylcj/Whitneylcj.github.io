{
  "name": "whitneylcj-github-io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "worker:dev": "wrangler dev --config workers/visitor-analytics/wrangler.toml",
    "worker:deploy": "wrangler deploy --config workers/visitor-analytics/wrangler.toml",
    "worker:migrate": "wrangler d1 migrations apply personal-website-visitors --remote --config workers/visitor-analytics/wrangler.toml",
    "worker:migrate:local": "wrangler d1 migrations apply personal-website-visitors --local --config workers/visitor-analytics/wrangler.toml"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@types/three": "^0.184.1",
    "astro": "^6.4.5",
    "d3-geo": "^3.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
